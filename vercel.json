{
  "buildCommand": "chmod +x scripts/build-web.sh && ./scripts/build-web.sh",
  "outputDirectory": "deploy",
  "rewrites": [
    {
      "source": "/api/notion/:path*",
      "destination": "/api/notion?path=:path*"
    },
    {
      "source": "/focus/:path*",
      "destination": "/focus/index.html"
    },
    {
      "source": "/((?!api/|focus/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(focus/)?manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/flutter_service_worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/pwa_service_worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/focus/flutter_service_worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/focus/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/focus/pwa_service_worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/focus/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
